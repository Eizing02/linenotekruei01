# ── Supabase ─────────────────────────────────────────────────
# ดูได้ที่: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Service Role Key (ใช้ใน API Routes เท่านั้น — ห้าม expose ฝั่ง client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── Vercel Cron Security ──────────────────────────────────────
# สร้างรหัสผ่านสุ่มเองได้ เช่น: openssl rand -hex 32
CRON_SECRET=your-secret-here

# ── LINE Bot ─────────────────────────────────────────────────
# (Optional: ตั้งค่าใน Settings tab ของ Dashboard ก็ได้)
# LINE_TOKEN=...
# LINE_USER_ID=...
